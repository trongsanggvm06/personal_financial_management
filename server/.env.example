# Copy to .env and adjust.
#
# Database: PostgreSQL (Neon). Lấy chuỗi kết nối ở dashboard Neon:
#   Project → Connection Details → chọn "Pooled connection" (khuyến nghị).
# Dán vào DATABASE_URL, giữ nguyên ?sslmode=require ở cuối.
DATABASE_URL="postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require"

JWT_SECRET="change-me"
PORT=4000
CORS_ORIGIN="http://localhost:5173"
NODE_ENV=development
