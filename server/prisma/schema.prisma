// Prisma schema for the personal finance app.
// Database: PostgreSQL (Neon). Set DATABASE_URL to your Neon connection string
// (dùng chuỗi kết nối có ?sslmode=require). `npm run setup` dùng `prisma db push`,
// chạy tốt trên endpoint pooled của Neon.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  createdAt    DateTime      @default(now())

  accounts     Account[]
  transactions Transaction[]
  savingsGoals SavingsGoal[]
  budgets      Budget[]
}

// A "ví"/account or fund the user owns (e.g. Ví chính, Tiết kiệm).
model Account {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  accent       String        @default("bg-indigo-500")
  createdAt    DateTime      @default(now())

  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  // Positive = thu (income), negative = chi (expense). Stored in VND (integer đồng).
  amount      Int
  description String
  category    String
  status      String   @default("Completed") // "Completed" | "Pending"
  date        DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([accountId])
}

model SavingsGoal {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  targetAmount  Int      // VND
  currentAmount Int      @default(0) // VND
  deadline      DateTime?
  accent        String   @default("bg-emerald-500")
  createdAt     DateTime @default(now())

  @@index([userId])
}

model Budget {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  category String
  limit    Int    // monthly limit in VND
  // Month this budget applies to, format "YYYY-MM". Null = applies every month.
  month    String?

  @@unique([userId, category, month])
  @@index([userId])
}
